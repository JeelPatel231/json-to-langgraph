from typing import Any
from pydantic import BaseModel

from core.engine.types import GenericState


class LLMWithToolsArgs(BaseModel):
    model: str
    messages: list[dict[str, str]]
    tools: list[str]


class Tool: ...


class ToolRegistry:
    def register(self, tool: Tool) -> None: ...

    def get(self, id: str) -> Tool: ...


class LLMWithToolsNode:
    @property
    def __name__(self):
        return "llm_with_tools"

    def __init__(self, tool_registry: ToolRegistry):
        self.__tool_registry = tool_registry

    def __call__(self, input: dict[str, Any], state: GenericState) -> dict[str, str]:
        parsed_input = LLMWithToolsArgs.model_validate(input)
        tools = [self.__tool_registry.get(tool_id) for tool_id in parsed_input.tools]
        # grab all the information of tools and append it to system prompt and then add the user messages to that conversation.
        while True:
            # make llm call with all the tools.

            # if any tool is called by the llm, call it here. append the result to messages.
            # loop back for llm to know what the tool result is.

            # if no tool calls, return the result.
            return {"response": "llm_with_tools"}
